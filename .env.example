# Project Root .env.example
# Copy to .env and fill in values

# ==========================================
# BACKEND CONFIGURATION
# ==========================================

# FastAPI Server
DEBUG=True
PORT=8000
HOST=0.0.0.0

# ==========================================
# AI & ML CONFIGURATION
# ==========================================

# Groq API (for LLaMA 3)
# Get from: https://console.groq.com
# Sign up, go to API Keys, create new key
# Format: gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx (56 chars)
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API (for BioBERT)
# Get from: https://huggingface.co/settings/tokens
# Create "Read" access token
# Format: hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_API_KEY=your_huggingface_token_here   

# ==========================================
# DATABASE CONFIGURATION
# ==========================================

# MongoDB Atlas (Free Tier)
# Get from: https://www.mongodb.com/cloud/atlas
# Create cluster, get connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/healthcare
MONGODB_URI=mongodb+srv://demo:demo@test.mongodb.net/healthcare

# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# AES-256 Encryption Key (32 bytes)
# Generate with: python -c "import os; print(os.urandom(32).hex())"
# Must be 64 hex characters (32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================

# Backend API URL for Frontend
VITE_API_URL=http://localhost:8000
# For production: https://api.yourdomain.com

# ==========================================
# DEPLOYMENT CONFIGURATION
# ==========================================

# For Render.com
# Set to False in production
DEBUG=False

# For Vercel
# Set your frontend URL
FRONTEND_URL=http://localhost:3000
# For production: https://yourdomain.com
