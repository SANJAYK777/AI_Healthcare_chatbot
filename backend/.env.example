# Environment Configuration for Backend
# Copy this to .env and fill in your actual values

# Groq API (for LLaMA 3)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace API (for BioBERT)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_token_here

# MongoDB Atlas Connection
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://username:password@cluster.mongodb.net/healthcare
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/healthcare

# Encryption Key (32 bytes)
# Generate with: python -c "import os; print(os.urandom(32).hex())"
ENCRYPTION_KEY=your-32-byte-encryption-key-here-256bits

# Server Configuration
DEBUG=True
PORT=8000
HOST=0.0.0.0

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "https://yourdomain.com"]
